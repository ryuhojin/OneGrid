{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "dist",
    "rootDir": ".",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"],
  "exclude": ["src/**/*.spec.ts"],
  "references": [
    { "path": "../../packages/adapters" },
    { "path": "../../packages/core" },
    { "path": "../../packages/dom" },
    { "path": "../../packages/react" },
    { "path": "../../packages/vue" },
    { "path": "../../packages/themes" }
  ]
}
