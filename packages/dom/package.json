{
  "name": "@onegrid/dom",
  "version": "0.0.0",
  "description": "DOM renderer shell for OneGrid.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/onegrid.umd.js",
  "jsdelivr": "./dist/onegrid.umd.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && pnpm run build:cdn",
    "build:cdn": "vite build --config vite.cdn.config.ts",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "dependencies": {
    "@onegrid/core": "workspace:*",
    "@onegrid/pagination": "workspace:*"
  }
}
