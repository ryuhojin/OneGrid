{
  "name": "@onegrid/pagination",
  "version": "0.0.0",
  "description": "Pagination model and UI bridge foundation for OneGrid.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "dependencies": {
    "@onegrid/core": "workspace:*"
  }
}
