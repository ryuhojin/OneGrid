{
  "name": "@onegrid/react",
  "version": "0.0.0",
  "description": "React bridge shell for OneGrid.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "dependencies": {
    "@onegrid/core": "workspace:*",
    "@onegrid/dom": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "react": "latest",
    "react-dom": "latest"
  }
}
