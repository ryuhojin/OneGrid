{
  "name": "@onegrid/vue",
  "version": "0.0.0",
  "description": "Vue bridge shell for OneGrid.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "dependencies": {
    "@onegrid/core": "workspace:*",
    "@onegrid/dom": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.4.0"
  },
  "devDependencies": {
    "vue": "latest"
  }
}
