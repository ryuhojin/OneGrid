{
  "name": "@onegrid/themes",
  "version": "0.0.0",
  "description": "Theme tokens and CSS for OneGrid.",
  "type": "module",
  "sideEffects": ["./dist/*.css", "./src/*.css"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": {
      "style": "./src/tokens.css",
      "default": "./src/tokens.css"
    },
    "./default.css": {
      "style": "./src/default.css",
      "default": "./src/default.css"
    },
    "./clean.css": {
      "style": "./src/clean.css",
      "default": "./src/clean.css"
    },
    "./compact.css": {
      "style": "./src/compact.css",
      "default": "./src/compact.css"
    },
    "./dark.css": {
      "style": "./src/dark.css",
      "default": "./src/dark.css"
    },
    "./high-contrast.css": {
      "style": "./src/high-contrast.css",
      "default": "./src/high-contrast.css"
    }
  },
  "files": ["dist", "src/*.css"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && pnpm run build:css",
    "build:css": "mkdir -p dist && cp src/*.css dist/",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  }
}
