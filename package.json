{
  "name": "onegrid",
  "version": "0.0.0",
  "private": true,
  "description": "Enterprise-grade frontend data grid monorepo.",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "typecheck": "turbo run typecheck",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test --config playwright.config.ts tests/e2e/features --project=chromium",
    "test:e2e:webkit": "playwright test --config playwright.config.ts tests/e2e/features --project=webkit",
    "test:e2e:edge": "playwright test --config playwright.config.ts tests/e2e/features --project=edge",
    "test:e2e:browser-matrix": "pnpm test:e2e && pnpm test:e2e:webkit && pnpm test:e2e:edge",
    "test:e2e:package-csp": "pnpm build && playwright test --config playwright.config.ts tests/e2e/packaging/package-csp.spec.ts --project=chromium",
    "test:e2e:security:browser-matrix": "node tests/e2e/security/run-browser-security-matrix.mjs",
    "test:e2e:visual": "playwright test --config playwright.config.ts tests/e2e/visual --project=chromium",
    "test:a11y": "playwright test --config playwright.config.ts tests/a11y --project=chromium",
    "test:perf:smoke": "vitest run --config vitest.config.ts tests/perf",
    "bench:metrics": "pnpm --filter @onegrid/core build && pnpm --filter @onegrid/benchmark build && pnpm --filter @onegrid/benchmark report",
    "build": "turbo run build",
    "docs:build": "pnpm --filter @onegrid/docs build"
  },
  "devDependencies": {
    "@changesets/cli": "latest",
    "@eslint/js": "latest",
    "@playwright/test": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "@vitejs/plugin-vue": "latest",
    "axe-core": "^4.11.3",
    "eslint": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "prettier": "latest",
    "turbo": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vitest": "latest"
  },
  "pnpm": {
    "overrides": {
      "@babel/plugin-transform-modules-systemjs": "7.29.4",
      "fast-uri": "3.1.2",
      "serialize-javascript": "7.0.5",
      "webpack": "5.104.1",
      "webpackbar": "file:tools/webpackbar-noop"
    }
  }
}
